import { useState, useEffect, useCallback, useRef } from "react";
import LyricsWindow from "./components/LyricsWindow";
import SettingsPanel from "./components/SettingsPanel";
import { SMTCData, LyricLine, AppSettings, DEFAULT_SETTINGS, LyricsResponse } from "./types";

function parseLRC(lrc: string): LyricLine[] {
  const lines: LyricLine[] = [];
  const regex = /\[(\d+):(\d+(?:\.\d+)?)\](.*)/g;
  let match: RegExpExecArray | null;

  while ((match = regex.exec(lrc)) !== null) {
    const mins = parseInt(match[1], 10);
    const secs = parseFloat(match[2]);
    const text = match[3].trim();
    if (text) {
      lines.push({ time: mins * 60 + secs, text });
    }
  }
  return lines.sort((a, b) => a.time - b.time);
}

export default function App() {
  const [settings, setSettings] = useState<AppSettings>(DEFAULT_SETTINGS);
  const [showSettings, setShowSettings] = useState(false);
  const [media, setMedia] = useState<SMTCData | null>(null);
  const [lyricLines, setLyricLines] = useState<LyricLine[]>([]);
  const [plainLyrics, setPlainLyrics] = useState("");
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [debugInfo, setDebugInfo] = useState("init");
  const currentSongRef = useRef("");
  const lastMediaRef = useRef<SMTCData | null>(null);
  const vanishTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);

  // Load settings
  useEffect(() => {
    fetch("/api/preferences")
      .then((r) => r.json())
      .then((prefs: Record<string, string>) => {
        if (Object.keys(prefs).length > 0) {
          setSettings((prev) => ({
            ...prev,
            fontSize: prefs.fontSize ? Number(prefs.fontSize) : prev.fontSize,
            fontFamily: prefs.fontFamily || prev.fontFamily,
            textColor: prefs.textColor || prev.textColor,
            highlightColor: prefs.highlightColor || prev.highlightColor,
            bgOpacity: prefs.bgOpacity ? Number(prefs.bgOpacity) : prev.bgOpacity,
            bgBlur: prefs.bgBlur ? Number(prefs.bgBlur) : prev.bgBlur,
          }));
        }
      })
      .catch(() => {});
    window.electronAPI?.setWindowOpacity(DEFAULT_SETTINGS.bgOpacity + 0.5);
  }, []);

  // Fetch lyrics
  const fetchLyrics = useCallback(async (title: string, artist: string) => {
    const key = `${title}|${artist}`;
    if (currentSongRef.current === key) return;
    currentSongRef.current = key;
    setLoading(true);
    setError("");
    setDebugInfo(`fetching: ${title} - ${artist}`);

    try {
      const url = `/api/lyrics?title=${encodeURIComponent(title)}&artist=${encodeURIComponent(artist)}`;
      const resp = await fetch(url);
      if (!resp.ok) {
        setDebugInfo(`fetch ${resp.status}`);
        setLyricLines([]);
        setPlainLyrics("");
        setError("歌词未找到");
        return;
      }
      const data: LyricsResponse = await resp.json();
      if (data.syncedLyrics) {
        setLyricLines(parseLRC(data.syncedLyrics));
        setPlainLyrics("");
        setDebugInfo(`synced lyrics, ${parseLRC(data.syncedLyrics).length} lines`);
      } else if (data.lyrics) {
        setPlainLyrics(data.lyrics);
        setLyricLines([]);
        setDebugInfo("plain lyrics");
      } else {
        setLyricLines([]);
        setPlainLyrics("");
        setError("歌词未找到");
      }
    } catch (e) {
      setDebugInfo(`fetch err: ${String(e)}`);
      setLyricLines([]);
      setPlainLyrics("");
      setError("歌词服务连接失败");
    } finally {
      setLoading(false);
    }
  }, []);

  // SMTC polling with sticky media (3s delay before hiding)
  useEffect(() => {
    if (!window.electronAPI) {
      setDebugInfo("no electronAPI");
      return;
    }
    setDebugInfo("polling...");

    const poll = setInterval(async () => {
      try {
        const data = await window.electronAPI.getSongStatus();
        if (!data) {
          // Keep last media for 3 seconds before clearing
          if (lastMediaRef.current && !vanishTimerRef.current) {
            vanishTimerRef.current = setTimeout(() => {
              setMedia(null);
              setLyricLines([]);
              setPlainLyrics("");
              setError("");
              currentSongRef.current = "";
              lastMediaRef.current = null;
              vanishTimerRef.current = null;
              setDebugInfo("media gone");
            }, 3000);
          }
          return;
        }

        // Cancel any pending vanish timer
        if (vanishTimerRef.current) {
          clearTimeout(vanishTimerRef.current);
          vanishTimerRef.current = null;
        }

        lastMediaRef.current = data;
        setMedia(data);
        setDebugInfo(`${data.title} - ${data.artist} [${data.source.split(".").pop()}]`);
        if (data.title) {
          fetchLyrics(data.title, data.artist);
        }
      } catch (e) {
        setDebugInfo(`poll err: ${String(e)}`);
      }
    }, 1000);

    return () => {
      clearInterval(poll);
      if (vanishTimerRef.current) clearTimeout(vanishTimerRef.current);
    };
  }, [fetchLyrics]);

  const saveSettings = useCallback(async (newSettings: AppSettings) => {
    setSettings(newSettings);
    window.electronAPI?.setWindowOpacity(newSettings.bgOpacity + 0.5);
    try {
      await fetch("/api/preferences", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          fontSize: String(newSettings.fontSize),
          fontFamily: newSettings.fontFamily,
          textColor: newSettings.textColor,
          highlightColor: newSettings.highlightColor,
          bgOpacity: String(newSettings.bgOpacity),
          bgBlur: String(newSettings.bgBlur),
        }),
      });
    } catch {}
  }, []);

  const isPlaying = media?.status === "Playing";

  return (
    <div className="app-container" style={{ fontFamily: settings.fontFamily }}>
      {/* Debug bar */}
      <div style={{
        position: "absolute", top: 32, left: 0, right: 0,
        fontSize: 10, color: "#0f0", background: "rgba(0,0,0,0.7)",
        padding: "2px 8px", zIndex: 20, pointerEvents: "none",
        whiteSpace: "nowrap", overflow: "hidden", textOverflow: "ellipsis",
      }}>
        {debugInfo}
      </div>

      {showSettings ? (
        <SettingsPanel settings={settings} onSave={saveSettings} onClose={() => setShowSettings(false)} />
      ) : (
        <LyricsWindow
          media={media}
          lyricLines={lyricLines}
          plainLyrics={plainLyrics}
          loading={loading}
          error={error}
          isPlaying={isPlaying}
          settings={settings}
        />
      )}

      <div className="mini-controls">
        <button className="ctrl-btn" onClick={() => setShowSettings((v) => !v)} title="设置">⚙</button>
        <button className="ctrl-btn" onClick={() => window.electronAPI?.minimizeToTray()} title="最小化到托盘">─</button>
        <button className="ctrl-btn ctrl-close" onClick={() => window.electronAPI?.minimizeToTray()} title="隐藏">✕</button>
      </div>
    </div>
  );
}

